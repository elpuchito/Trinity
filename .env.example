# ============================================
# TriageForge — Environment Configuration
# ============================================
# See QUICKGUIDE.md for full setup instructions.
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- Google Gemini API ---
# Your Google Cloud API key for Gemini 3.1 Flash Lite Preview
GOOGLE_API_KEY=your-gemini-api-key-here

# --- PostgreSQL ---
POSTGRES_USER=triageforge
POSTGRES_PASSWORD=triageforge_secret_change_me
POSTGRES_DB=triageforge
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://triageforge:triageforge_secret_change_me@postgres:5432/triageforge

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- ChromaDB ---
CHROMADB_HOST=chromadb
CHROMADB_PORT=8000

# --- OpenTelemetry ---
OTEL_SERVICE_NAME=triageforge-backend
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317

# --- Application ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# --- Mocked Integrations ---
# These are mocked but structured to be swappable with real services
LINEAR_API_KEY=mock-linear-api-key
LINEAR_TEAM_ID=mock-team-id
SLACK_WEBHOOK_URL=http://backend:8000/mock/slack/webhook
EMAIL_SMTP_HOST=backend
EMAIL_SMTP_PORT=1025
EMAIL_FROM=triageforge@example.com
